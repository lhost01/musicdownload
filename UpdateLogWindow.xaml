<Window x:Class="网易云音乐下载.UpdateLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="更新日志 - MusicBox"
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,12">
                        <Border Width="32" Height="32"
                                CornerRadius="8"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4facfe" Offset="0"/>
                                    <GradientStop Color="#FF00f2fe" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="M"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="MusicBox 更新日志"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✕"
                            FontSize="14"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#757575"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFFFE5E5"/>
                                        <Setter Property="Foreground" Value="#FFFF0000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24">
                <StackPanel>
                    <!-- 版本信息 -->
                    <Border Background="#E3F2FD"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="2026.04.19 更新"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#1976D2"/>
                            <TextBlock Text="2026 年 4 月 19 日"
                                       FontSize="13"
                                       Foreground="#616161"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 更新内容 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="本次更新"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"
                                   Margin="0,0,0,12"/>

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="歌单识别逻辑升级"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#212121"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="• 新增更严格的歌单识别机制，避免把无关目录误识别为歌单"
                                           FontSize="13"
                                           Foreground="#616161"
                                           Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="• 仅识别程序歌单标记，并结合目录结构判断是否为真实歌单"
                                           FontSize="13"
                                           Foreground="#616161"
                                           Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="• 旧数据只会在明显像真实歌单时迁移，减少历史脏路径干扰"
                                           FontSize="13"
                                           Foreground="#616161"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="界面与交互优化"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#212121"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="• 更新了导航栏 UI，整体层次和视觉风格更统一"
                                           FontSize="13"
                                           Foreground="#616161"
                                           Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="• 修复了播放进度条不同步、无法拖动的问题"
                                           FontSize="13"
                                           Foreground="#616161"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="新增更新日志提示"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#212121"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="• 新增“下次不再提示”选项，勾选后本次更新日志将不再自动弹出"
                                           FontSize="13"
                                           Foreground="#616161"
                                           Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="• 后续如果有新的更新日志版本，仍会继续提醒"
                                           FontSize="13"
                                           Foreground="#616161"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Background="#FFF3E0"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="💡 温馨提示"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F57C00"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="本项目仅供学习研究使用，请勿用于商业用途。"
                                       FontSize="13"
                                       Foreground="#616161"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <CheckBox x:Name="SkipThisVersionCheckBox"
                                  Content="下次不再提示"
                                  FontSize="13"
                                  Foreground="#212121"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="勾选后将不再自动弹出本次更新日志，后续新版本更新仍会继续提醒。"
                                   FontSize="12"
                                   Foreground="#757575"
                                   Margin="24,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="我知道了"
                            Width="120"
                            Height="36"
                            Background="#3F51B5"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="Medium"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OKButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF5268B0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
</Window>
